          "default": "Nose"
        },
        {
          "type": "textarea",
          "id": "notes",
          "label": "Tasting notes"
        }
      ]
    },
    {
      "type": "pairing",
      "name": "Pairing Suggestion",
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Icon (emoji or text)",
          "default": "🍫"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Pairing name",
          "default": "Dark Chocolate"
        },
        {
          "type": "text",
          "id": "detail",
          "label": "Detail",
          "default": "70%+ cacao"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Tasting Notes Infographic",
      "blocks": [
        { "type": "stat", "settings": { "value": "17", "label": "Years Aged" } },
        { "type": "stat", "settings": { "value": "107.6", "label": "Proof" } },
        { "type": "stat", "settings": { "value": "#1", "label": "Single Barrel" } },
        { "type": "stat", "settings": { "value": "Kentucky", "label": "Origin" } },
        { "type": "flavor", "settings": { "name": "Caramel", "intensity": 90 } },
        { "type": "flavor", "settings": { "name": "Dark Oak", "intensity": 85 } },
        { "type": "flavor", "settings": { "name": "Vanilla", "intensity": 75 } },
        { "type": "flavor", "settings": { "name": "Leather", "intensity": 70 } },
        { "type": "flavor", "settings": { "name": "Dried Fruit", "intensity": 65 } },
        { "type": "flavor", "settings": { "name": "Tobacco", "intensity": 55 } },
        { "type": "flavor", "settings": { "name": "Baking Spice", "intensity": 80 } },
        { "type": "flavor", "settings": { "name": "Cherry", "intensity": 50 } },
        { "type": "stage", "settings": { "icon": "👃", "name": "Nose", "notes": "Rich dark caramel and toasted oak lead, followed by waves of dried cherry, old leather, and a delicate thread of pipe tobacco. Deeper still, there is brown butter, holiday baking spice, and a faint wisp of cedar." } },
