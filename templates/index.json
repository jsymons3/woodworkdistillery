{"sections":{"hero-video":{"type":"hero-video","settings":{"title":"The WoodWork\nCollective","title_size":72,"subheading":"Cask-Driven Whiskey of Uncommon Character","link_text":"Experience Our Process","link":"https:\/\/youtu.be\/l9EbPPl01O8","text_align":"vertical-center horizontal-center","video_url":"https:\/\/youtu.be\/l9EbPPl01O8","overlay_opacity":40,"section_height":"750px","mobile_height":"auto"}},"rich-text-intro":{"type":"rich-text","blocks":{"heading":{"type":"heading","settings":{"title":"Spirit. Wood. Time."}},"text":{"type":"text","settings":{"enlarge_text":true,"text":"<p>The WoodWork Collective Distilling Company is a whiskey house devoted to the art of selection, blending, and secondary maturation. We believe great spirits are not manufactured into existence but carefully revealed\u2014through patience, restraint, and an unwavering respect for the transformative relationship between spirit and oak.<\/p>"}}},"block_order":["heading","text"],"settings":{"align_text":"center","narrow_column":true,"divider":false}},"featured-collection-switcher":{"type":"featured-collection-switcher","settings":{"title":"Current Releases","collection1":"single-barrel-ryes","collection2":"single-barrel-bourbons","per_row":2,"view_all":true,"divider":false}},"fading-images":{"type":"fading-images","blocks":{"1498501481980-0":{"type":"image","settings":{"image":"shopify:\/\/shop_images\/bourbonhorses_5a3232c8-cdaf-4caf-a6d7-eaaf2fab6182.jpg","slide_title1":"Selected with Judgment","slide_title2":"Released with Conviction"}},"1498501481980-1":{"type":"image","settings":{"image":"shopify:\/\/shop_images\/AAltschulerbourbontree.jpg","slide_title1":"Secondary Maturation","slide_title2":"as Creative Medium"}},"1498501481980-2":{"type":"image","settings":{"image":"shopify:\/\/shop_images\/ALTSCHULER16MIZBARN.jpg","slide_title1":"Small Batch Precision","slide_title2":"Singular Releases"}}},"block_order":["1498501481980-0","1498501481980-1","1498501481980-2"],"custom_css":[],"se